import os
from fastapi import FastAPI, HTTPException, Header
from pydantic import BaseModel
import litellm

app = FastAPI(title="Enterprise AI Gateway POC", version="1.0")

class ChatRequest(BaseModel):
    message: str
    team_id: str

@app.post("/v1/chat")
async def ai_gateway_route(request: ChatRequest, authorization: str = Header(None)):
    # Security: Internal Token Check
    if authorization != "Bearer internal_secret_token_123":
        raise HTTPException(status_code=401, detail="Unauthorized microservice")

    # Fallback Logic: GPT-4o -> Claude-3
    models_to_try = ["gpt-4o-mini", "claude-3-haiku-20240307"]
    messages = [{"role": "user", "content": request.message}]

    for model in models_to_try:
        try:
            response = litellm.completion(model=model, messages=messages, timeout=5.0)
            tokens_used = response.usage.total_tokens
            
            print(f"[FinOps] Team: {request.team_id} | Model: {model} | Tokens: {tokens_used}")

            return {
                "status": "success",
                "model_routed_to": model,
                "response": response.choices[0].message.content,
                "tokens_consumed": tokens_used
            }
        except Exception as e:
            print(f"[Fallback Alert] {model} failed. Next...")
            continue 

    raise HTTPException(status_code=503, detail="All AI providers down.")
